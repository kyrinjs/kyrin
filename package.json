{
  "name": "kyrin",
  "version": "0.0.1-experimental.14",
  "description": "A simple, fast web framework for Bun",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "bin": {
    "kyrin": "./bin/kyrin"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run build:lib && bun run build:cli && bun run build:types",
    "build:lib": "bun build src/lib.ts --outdir dist --target bun --minify",
    "build:cli": "bun build src/cli/spawn.ts --outdir dist/cli --target node",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "spawn": "bun run src/cli/spawn.ts"
  },
  "keywords": [
    "bun",
    "framework",
    "typescript",
    "web",
    "api",
    "rest",
    "http",
    "server",
    "fast",
    "batteries-included"
  ],
  "author": {
    "name": "A70III",
    "url": "https://github.com/A70III"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kyrinjs/Kyrin.git"
  },
  "bugs": {
    "url": "https://github.com/kyrinjs/Kyrin/issues"
  },
  "homepage": "https://github.com/kyrinjs/Kyrin#readme",
  "license": "MIT",
  "dependencies": {
    "prompts": "^2.4.2",
    "mysql2": "^3.22.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/prompts": "^2.4.9",
    "typescript": "^5",
    "zod": "3"
  }
}
